{
  "expo": {
    "name": "Caffe",
    "slug": "Caffe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pizzerie_logo_copy.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/pizzerie_logo_copy.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B0000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/pizzerie_logo_copy.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
